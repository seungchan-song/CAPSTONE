# ============================================
# K-RAG 환경변수 설정 파일
# 이 파일을 복사하여 .env 파일로 만들고 실제 키를 입력하세요.
# cp .env.example .env
# ============================================

# === OpenAI API (GPT-4o mini 생성기 및 sLLM 교차검증용) ===
OPENAI_API_KEY=sk-여기에-실제-키-입력

# === 네이버 클로바 API (HyperCLOVA X 생성기용) ===
NAVER_CLOVA_API_KEY=여기에-실제-키-입력
NAVER_CLOVA_API_URL=https://clovastudio.apigw.ntruss.com

# === 모델 경로 ===
# 파인튜닝된 KPF-BERT 모델 가중치 경로
KPF_BERT_MODEL_PATH=models/kpf-bert-kdpii

# === 실험 설정 ===
# 기본 설정 파일 경로
KRAG_CONFIG_PATH=config/default.yaml

# 실험 결과 저장 경로
KRAG_RESULTS_PATH=data/results

# === 로깅 ===
# 로그 레벨: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
